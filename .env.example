# Saxo OpenAPI SIM (paper trading) — generate a 24-Hour Access Token at
# https://www.developer.saxo/openapi/token/current after creating a Simulation
# Application. Re-paste this every ~24h; it expires.
SAXO_TOKEN=
SAXO_BASE_URL=https://gateway.saxobank.com/sim/openapi

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Comma-separated instruments the agent is allowed to look at / trade.
# Saxo's SIM environment only provides real market data for FxSpot (Forex) —
# equities/ETFs always return NoAccess in SIM (see README). Default watchlist
# is therefore Forex pairs.
WATCHLIST=EURUSD,USDJPY,GBPUSD

# Saxo AssetType for the watchlist above (FxSpot, Stock, etc.) — must match
# what the symbols actually are, or instrument search will fail.
ASSET_TYPE=FxSpot

# Hard cap on units per order, enforced regardless of what the model suggests.
# FxSpot trades in currency units (Saxo's typical minimum is ~1,000), so this
# is much higher than a sensible per-share cap for stocks.
MAX_ORDER_QUANTITY=1000

# Hard cap on total open exposure (sum of position amounts) per symbol.
# Only applies to "buy" decisions — closing/reducing (sell) is never capped.
# Once a symbol hits this, buy quantity is clamped down (to 0 if already at
# or over the cap), which pushes the agent toward other watchlist symbols
# instead of endlessly concentrating in one.
MAX_SYMBOL_EXPOSURE=5000

# Safety switch: agent only logs intended trades until this is "true"
EXECUTE=false
